# --- 필수: Supabase (프로젝트 설정 > API) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- 필수: SEC EDGAR 요청 시 식별 (이름 또는 이메일, SEC 정책 준수) ---
EDGAR_IDENTITY=Your Name your.email@example.com

# --- 선택: 워치리스트 JSON 경로 (기본: 프로젝트 config/watchlist.json) ---
# WATCHLIST_PATH=/absolute/path/to/watchlist.json

# --- 선택: ingest-watchlist / extract-facts-watchlist 티커 간 대기(초). 기본 0.65 ---
# INGEST_TICKER_SLEEP_SEC=0.65

# --- 선택: facts CLI에서 --forms 미지정 시 코드 기본(10-Q,10-K). 환경변수로 강제하진 않음 ---
# (예: python3 src/main.py extract-facts-single --ticker NVDA --forms 10-Q,10-K)

# --- 선택: 팩터 패널 공식 버전 (기본 v1). 공식 변경 시 v2 등으로 올려 새 유니크 행 적재 ---
# FACTOR_VERSION=v1

# --- Phase 4: 시장 데이터 프로바이더 (yahoo_chart | stub). stub 은 네트워크 없이 스텁 데이터 ---
# MARKET_DATA_PROVIDER=yahoo_chart

# --- Phase 4: 일봉 수집 기본 lookback (ingest-market-prices --lookback-days 기본값) ---
# MARKET_PRICE_LOOKBACK_DAYS=400

# --- Phase 5: run-factor-validation / report-factor-summary / smoke-research 는 Supabase만 사용(추가 ENV 없음) ---

# --- 선택: edgartools 캐시 디렉터리 (미설정 시 프로젝트 루트 .edgar_cache 사용 권장) ---
# EDGAR_LOCAL_DATA_DIR=/absolute/path/to/.edgar_cache

# --- 선택: 이후 AI 계층용 (코드에서 Phase 1 미사용) ---
# OPENAI_API_KEY=

# --- 선택: Sentry (예약) ---
# SENTRY_DSN=

# --- Phase 11: FMP earnings call transcript PoC (단일 벤더) ---
# 미설정 시 probe 는 not_configured / ingest 불가 (가짜 성공 없음).
# FMP_API_KEY=
# TRANSCRIPTS_PROVIDER=fmp

# --- AGH v1 Patch 8 E4: Railway deployment (web + worker) ---
# Railway 는 컨테이너에 $PORT 를 주입합니다. 로컬에서 src/phase47_runtime/app.py
# 를 그대로 실행하면 $PORT 가 없을 때 127.0.0.1:8765 로 바인드하고,
# $PORT 가 설정되어 있으면 0.0.0.0:$PORT 로 바인드합니다. 별도 PORT 를
# 수동 지정할 필요는 없습니다.
# PORT=8080

# --- Phase 47 cockpit (로컬 개발용 기본값; Railway 는 위 $PORT 가 우선) ---
# PHASE47_HOST=127.0.0.1
# PHASE47_PORT=8765
# PHASE47_PHASE46_BUNDLE=docs/operator_closeout/phase46_founder_decision_cockpit_bundle.json
# PHASE47_REPO_ROOT=

# --- AGH v1 LLM provider + bounded invoke gate ---
# METIS_HARNESS_LLM_PROVIDER=fixture | openai | anthropic
# METIS_TODAY_SOURCE=registry   # MVP 기본값; 변경 금지 권장
# METIS_UI_INVOKE_ENABLED=0     # 1 이면 UI 에서 샌드박스 enqueue 가능
# ANTHROPIC_API_KEY=
# (OPENAI_API_KEY 는 위 OPENAI_API_KEY 항목을 재사용)

# --- AGH v1 Patch 8 scheduler worker (worker: Procfile 프로세스) ---
# 기본 30s 간격으로 tick loop 을 돌립니다. 더 촘촘한 반복이 필요하면
# AGH_WORKER_SLEEP 을 내리고 Procfile 의 --sleep $AGH_WORKER_SLEEP 를
# 맞춰주세요. (현재 Procfile 은 고정 30s.)
# AGH_WORKER_SLEEP=30

# --- Patch 12 Private Beta (invite-only auth + account-level telemetry) ---
# 전부 optional. 미설정 시 서버는 /api/* 에 인증을 요구하지 않고 (graceful
# downgrade) /login.html 은 "not configured" 안내만 보여줍니다. Railway에
# 배포할 때만 아래 5개를 채워 주세요.
#
# 1) anon key: supabase-js 가 magic link 를 시작할 때 사용하는 공개 키.
#    Supabase 대시보드 > Project Settings > API > Project API keys > anon.
# SUPABASE_ANON_KEY=
#
# 2) JWT secret: 서버에서 HS256 검증에 사용. Supabase 대시보드 > Project
#    Settings > API > JWT Settings > JWT Secret. 절대 클라이언트에 노출 금지.
# SUPABASE_JWT_SECRET=
#
# 3) Magic link redirect. 배포된 Railway 주소 + /login.html#callback.
# SUPABASE_AUTH_REDIRECT_URL=https://YOUR_APP.up.railway.app/login.html#callback
#
# 4) 초대장 enforce 모드. enforce | shadow | off. 기본값: SUPABASE_URL +
#    SERVICE_ROLE_KEY 가 모두 있으면 enforce, 아니면 off.
# METIS_BETA_ALLOWLIST_MODE=enforce
#
# 5) 텔레메트리 ingest on/off. 0 이면 /api/events 는 no-op. 기본 1.
# METIS_TELEMETRY_ENABLED=1
