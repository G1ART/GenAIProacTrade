{
  "contract": "AGH_V1_PATCH_9_PRODUCTION_BUNDLE_ACTUALIZATION_EVIDENCE_V1",
  "milestone": 20,
  "patch_nature": "productionize_self_serve_scale_closure",
  "not_a_demo_theater_patch": true,
  "scope": "Scope A — promote the v2 brain bundle to be the primary runtime production bundle with a quick integrity gate, fallback-aware observability, and production-tier integrity hardening.",
