{
  "contract": "PATCH_10A_HARD_SPLIT_EVIDENCE_V1",
  "milestone": "10A",
  "patch_nature": "product_shell_rebuild_v1",
  "scope": "Scope A — hard 2-file split between customer-facing Product Shell (/) and internal Ops Cockpit (/ops, env-gated).",
  "workorder_reference": "docs/plan/METIS_Product_Shell_Rebuild_v1_Patch_10A_Plan_KR.md#\ud558\ub4dc 2-\ud30c\uc77c \ubd84\ub9ac",
  "architectural_decision": {
    "root_path": {
      "serves": "src/phase47_runtime/static/index.html",
      "pulls_in": [
        "src/phase47_runtime/static/product_shell.css",
        "src/phase47_runtime/static/product_shell.js"
      ]
