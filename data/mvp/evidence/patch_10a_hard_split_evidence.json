    {"from": "src/phase47_runtime/static/app.js",     "to": "src/phase47_runtime/static/ops.js",   "git_mv": true}
  ],
  "new_files": [
    "src/phase47_runtime/static/index.html",
    "src/phase47_runtime/static/product_shell.js",
    "src/phase47_runtime/static/product_shell.css",
    "src/phase47_runtime/product_shell/__init__.py",
    "src/phase47_runtime/product_shell/view_models.py"
  ],
  "routing_touchpoints": {
    "file": "src/phase47_runtime/app.py",
    "root_route_serves_product_shell_html": true,
    "ops_route_env_gated": true,
    "product_api_dispatch_in": "src/phase47_runtime/routes.py",
    "product_api_route_registered": "/api/product/today"
  },
  "regression_impact": {
    "legacy_test_path_references_updated": [
      "src/tests/test_agh_v1_patch6_copy_no_leak.py",
      "src/tests/test_agh_v1_patch6_ui_renderer_surface.py",
      "src/tests/test_agh_v1_patch7_product_hardening_surface.py",
      "src/tests/test_agh_v1_patch8_production_graduation_surface.py",
      "src/tests/test_agh_v1_patch9_production_surface.py"
    ],
    "legacy_runbook_script_path_references_updated": [
      "scripts/agh_v1_patch_6_demo_freeze_runbook.py",
      "scripts/agh_v1_patch_7_product_hardening_runbook.py",
      "scripts/agh_v1_patch_8_production_graduation_runbook.py",
      "scripts/agh_v1_patch_9_production_graduation_runbook.py"
    ],
    "full_regression_remains_green_excluding_pre_existing_phase39_failure": true
  },
  "tests": [
