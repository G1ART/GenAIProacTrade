    "live_with_caveat":  {"label_ko": "\uc2e4\uc2dc\uac04 \ub370\uc774\ud130 (\uc77c\ubd80 \uc81c\ud55c)"},
    "sample":            {"label_ko": "\uc0d8\ud50c \ub370\uc774\ud130"},
    "preparing":         {"label_ko": "\uc900\ube44 \uc911"}
  },
  "tests": [
